{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BroKnowMySparkAnalyzer",
  "version": "0.1.0",
  "identifier": "io.github.broknowmyorg.broknowmysparkanalyzer",
  "build": {
    "beforeDevCommand": "pnpm run dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "BroKnowMySparkAnalyzer",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 640,
        "decorations": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
